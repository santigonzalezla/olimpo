---
interface Props {
  name: string;
  description: string;
  beds: number;
  baths: number;
  image: string;
}

const { name, description, beds, baths, image } = Astro.props;

import BedIcon from "../../assets/svg/bed.svg";
import BathIcon from "../../assets/svg/bath.svg";
import PlansCta from "./PlansCta/PlansCta";
---

<div class="unitCard">
  <div class="unitCardImage">
    <img src={image} alt={name} />
  </div>
  <div class="unitCardInfo">
    <h3 class="unitCardName">{name}</h3>
    <p class="unitCardDesc">{description}</p>
    <div class="unitCardFooter">
      <div class="unitCardSpecs">
        <BedIcon class="icon" />
        <span>{beds}</span>
        <span class="dot">·</span>
        <BathIcon class="icon" />
        <span>{baths}</span>
      </div>
      <PlansCta client:load name={name} />
    </div>
  </div>
</div>

<style>
  .unitCard {
    background: #fff;
    width: 615px;
    height: 471px;
    display: flex;
    flex-direction: column;
  }

  .unitCardImage {
    width: 100%;
    height: 252px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .unitCardImage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .unitCardInfo {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 28px 32px 24px;
    gap: 10px;
  }

  .unitCardName {
    font-family: var(--f-stardom);
    font-size: 26px;
    line-height: 1.2;
    color: #000;
  }

  .unitCardDesc {
    font-family: 'Satoshi', sans-serif;
    font-size: 16px;
    line-height: 24px;
    color: #000;
    flex: 1;
  }

  .unitCardFooter {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .unitCardSpecs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Satoshi', sans-serif;
    font-size: 16px;
    color: #d9d9d9;
  }

  .dot {
    color: #d9d9d9;
  }

  .icon {
    width: 15px;
    height: 15px;
    object-fit: contain;
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .unitCard {
      width: 300px;
      height: 80%;
      flex-shrink: 0;
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
    }

    .unitCardImage {
      flex: 2;
      min-height: 0;
      height: auto;
    }

    .unitCardInfo {
      padding: 14px 18px 14px;
      gap: 6px;
      flex-shrink: 0;
    }

    .unitCardName {
      font-size: 20px;
    }

    .unitCardDesc {
      font-size: 13px;
      line-height: 1.4;
      flex: none;
    }

    .unitCardSpecs {
      font-size: 13px;
    }

  }
</style>
