---
import ArrowRight from "../../assets/svg/arrowRight.svg";
---

<div class="formBox">
  <form class="contactForm" action="#" method="POST">
    <input class="field" type="text" name="nombre" placeholder="Nombre" required />
    <input class="field" type="email" name="email" placeholder="Email" required />
    <div class="row">
      <input class="field" type="tel" name="telefono" placeholder="Teléfono" />
      <div class="selectWrap">
        <select class="field select" name="tipo" required>
          <option value="" disabled selected>Tipo de apartamento</option>
          <option value="studio">Apartaestudio</option>
          <option value="3hab">3 Alcobas</option>
        </select>
        <svg class="selectArrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </div>
    </div>
    <textarea class="field textarea" name="mensaje" placeholder="Mensaje"></textarea>
    <button type="submit" class="submit">
      Enviar Mensaje
      <ArrowRight class="submitIcon" />
    </button>
  </form>
</div>

<style>
  .formBox {
    background: #243447;
    padding: 32px;
    width: 100%;
  }

  .contactForm {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .field {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    box-sizing: border-box;
    display: block;
    width: 100%;
    height: 54px;
    padding: 0 20px;
    background: #000a1b;
    border: none;
    border-radius: 0;
    font-family: 'Satoshi', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #fff;
    outline: none;
    transition: background 0.2s;
  }

  .field::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .field:focus {
    background: #001428;
  }

  .selectWrap {
    position: relative;
  }

  .select {
    cursor: pointer;
    padding-right: 36px;
  }

  .select option {
    background: #0d1f30;
    color: #fff;
  }

  .selectArrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }

  .textarea {
    height: 130px;
    padding: 16px 20px;
    resize: none;
  }

  .submit {
    -webkit-appearance: none;
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    height: 54px;
    padding: 0 32px;
    background: var(--c-blue);
    color: #fff;
    font-family: 'Satoshi', sans-serif;
    font-weight: 600;
    font-size: 15px;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .submit:hover { opacity: 0.85; }

  .submitIcon {
    width: 18px;
    height: 18px;
    stroke: white;
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .formBox { padding: 24px 20px; }
    .row { grid-template-columns: 1fr; }
    .submit { width: 100%; justify-content: center; }
  }
</style>
