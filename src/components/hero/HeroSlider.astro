---
import fachada1 from "../../assets/images/fachada1.png";
import fachada2 from "../../assets/images/fachada2.png";
import zonasocial from "../../assets/images/zonasocial.png";

const slides = [fachada1.src, fachada2.src, zonasocial.src];
---

<div class="heroSlider" id="heroSlider">
    {slides.map((src, i) => (
            <img
                    class="heroSlide"
                    src={src}
                    alt=""
                    role="presentation"
                    data-slide={i}
            />
    ))}
    <div class="heroOverlay"></div>
    <div class="heroDots" id="heroDots">
        {slides.map((_, i) => (
                <button
                        class="heroDot"
                        data-dot={i}
                        aria-label={`Imagen ${i + 1}`}
                />
        ))}
    </div>
</div>

<style>
    .heroSlider {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .heroSlide {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.8s ease;
    }

    .heroSlide.active {
        opacity: 0.8;
    }

    .heroOverlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 1;
    }

    .heroDots {
        position: absolute;
        bottom: 48px;
        left: 99px;
        display: flex;
        gap: 8px;
        z-index: 5;
    }

    .heroDot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.4);
        border: none;
        cursor: pointer;
        padding: 0;
        transition: background 0.3s;
    }

    .heroDot.active {
        background: #FFF;
    }

    @media (max-width: 767px) {
        .heroDots {
            bottom: 32px;
            left: 24px;
        }
    }
</style>

<script>
    const slider = document.getElementById("heroSlider") as HTMLElement;
    const slides = slider.querySelectorAll<HTMLElement>(".heroSlide");
    const dots = slider.querySelectorAll<HTMLButtonElement>(".heroDot");

    let current = 0;
    const total = slides.length;

    function goTo(index: number)
    {
        slides[current].classList.remove("active");
        dots[current].classList.remove("active");
        current = index;
        slides[current].classList.add("active");
        dots[current].classList.add("active");
    }

    goTo(0);

    let timer = setInterval(() => goTo((current + 1) % total), 5000);

    dots.forEach((dot, i) =>
    {
        dot.addEventListener("click", () =>
        {
            clearInterval(timer);
            goTo(i);
            timer = setInterval(() => goTo((current + 1) % total), 5000);
        });
    });
</script>
