---
const links = [
  { label: "Proyecto", href: "#proyecto" },
  { label: "Planos", href: "#planos" },
  { label: "Precios", href: "#precios" },
  { label: "Ubicación", href: "#ubicacion" },
];
---

<ul class="navLinks">
  {links.map((link) => (
    <li><a href={link.href}>{link.label}</a></li>
  ))}
</ul>

<style>
  .navLinks {
    display: flex;
    gap: 32px;
    margin: 0;
  }

  .navLinks a {
    color: #fff;
    font-family: var(--f-satoshi);
    font-size: 16px;
    font-weight: 300;
    line-height: 1.4;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .navLinks a:hover {
    opacity: 0.65;
  }
</style>
