---
import UnitCard from "../components/units/UnitCard.astro";
import PlansModal from "../components/units/PlansModal/PlansModal";

const floorPlanImg = "https://www.figma.com/api/mcp/asset/2bea5c45-ecb6-43e9-8a1b-a28b196a3a8e";

const units = [
  {
    name: "Apartaestudio",
    description:
      "Funcional, moderno y pensado para quien quiere vivir bien sin complicaciones. Tu primer hogar propio, en el lugar correcto.",
    beds: 1,
    baths: 1,
    image: floorPlanImg,
  },
  {
    name: "3 Alcobas",
    description:
      "El hogar que tu familia merece. Espacio de sobra para vivir, crecer y crear los recuerdos que duran toda la vida.",
    beds: 3,
    baths: 2,
    image: floorPlanImg,
  },
];
---

<section class="units" id="planos">
  <h2 class="unitsTitle">Es hora de elegir tu espacio ideal</h2>
  <div class="unitsCardsWrap">
    <div class="unitsGrid">
      {units.map((unit) => (
        <UnitCard
          name={unit.name}
          description={unit.description}
          beds={unit.beds}
          baths={unit.baths}
          image={unit.image}
        />
      ))}
    </div>
  </div>
</section>
<PlansModal client:load />

<style>
  .units {
    background: var(--c-dark);
    height: 800px;
    padding: 80px var(--px) 0;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .unitsCardsWrap {
    display: contents;
  }

  .unitsTitle {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 42px;
    line-height: 1.4;
    color: #fff;
    max-width: 420px;
  }

  .unitsGrid {
    display: flex;
    gap: 15px;
  }

  @media (max-width: 1024px) {
    .units {
      height: auto;
      padding-bottom: 60px;
    }

    .unitsTitle {
      font-size: 34px;
    }
  }

  @media (max-width: 767px) {
    .units {
      height: 100dvh;
      padding: 48px var(--px) 48px;
      gap: 24px;
    }

    .unitsTitle {
      font-size: 28px;
      flex-shrink: 0;
    }

    .unitsCardsWrap {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }

    .unitsGrid {
      flex: 1;
      min-height: 0;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 12px;
      scrollbar-width: none;
      align-items: center;
    }

    .unitsGrid::-webkit-scrollbar {
      display: none;
    }
  }
</style>
