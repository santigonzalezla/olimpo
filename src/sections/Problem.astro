---
import largeImgSrc from "../assets/images/fachada4.png";
import smallImg1Src from "../assets/images/fachada3.png";
import smallImg2Src from "../assets/images/zonasocial.png";
import smallImg3Src from "../assets/images/lobby1.png";

const largeImg = largeImgSrc.src;
const smallImg1 = smallImg1Src.src;
const smallImg2 = smallImg2Src.src;
const smallImg3 = smallImg3Src.src;
---

<section class="problem" id="proyecto">
  <div class="problemText">
    <h2 class="problemTitle">Conoce tu nuevo hogar: Olimpo</h2>
    <div class="problemBody">
      <p>
        Un proyecto residencial desarrollado en Valledupar, pensado para
        familias que buscan calidad de vida en un entorno moderno y bien
        ubicado.
      </p>
      <p>
        Apartaestudios y apartamentos de 3 alcobas disponibles en preventa,
        con espacios diseñados para el día a día de quienes merecen más.
      </p>
    </div>
    <a href="#contacto" class="problemCta">¡Hablemos Ya!</a>
    <p class="problemTagline">
      Arquitectura moderna · Acabados de calidad<br />Espacios que enamoran
    </p>
  </div>

  <div class="problemImages">
    <div class="problemSmalls">
      <img src={smallImg1} alt="Olimpo exterior" />
      <img src={smallImg2} alt="Olimpo exterior" />
      <img src={smallImg3} alt="Olimpo exterior" />
    </div>
    <div class="problemLarge">
      <img src={largeImg} alt="Olimpo proyecto" />
    </div>
  </div>
</section>

<style>
  .problem {
    display: flex;
    align-items: center;
    height: 800px;
    padding: 0 var(--px);
    gap: 100px;
    background: #fff;
  }

  .problemText {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 420px;
    flex-shrink: 0;
  }

  .problemTitle {
    font-size: 42px;
    color: #131b23;
  }

  .problemBody {
    display: flex;
    flex-direction: column;
    gap: 16px;
    font-size: 16px;
    line-height: 1.4;
    color: var(--c-body);
    max-width: 315px;
  }

  .problemCta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 45px;
    width: 195px;
    background: var(--c-navy);
    color: #fff;
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .problemCta:hover {
    opacity: 0.8;
  }

  .problemTagline {
    font-family: var(--f-stardom);
    font-size: 14px;
    line-height: 1.4;
    color: #000;
  }

  .problemImages {
    display: grid;
    grid-template-columns: 195px 1fr;
    gap: 15px;
    height: 650px;
    flex: 1;
  }

  .problemSmalls {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .problemSmalls img {
    flex: 1;
    width: 195px;
    height: 194px;
    object-fit: cover;
  }

  .problemLarge img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .problem {
      height: auto;
      padding: 60px var(--px);
      gap: 48px;
    }

    .problemText {
      width: 320px;
    }

    .problemTitle {
      font-size: 32px;
    }

    .problemImages {
      height: 500px;
    }
  }

  @media (max-width: 767px) {
    .problem {
      flex-direction: column;
      height: 100dvh;
      padding: 48px var(--px) 40px;
      gap: 50px;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .problemImages {
      order: -1;
      display: flex;
      flex: none;
      height: auto;
      width: 100%;
      grid-template-columns: unset;
    }

    .problemSmalls {
      flex-direction: row;
      gap: 8px;
      width: 100%;
    }

    .problemSmalls img {
      width: 88px;
      height: 88px;
    }

    .problemLarge {
      display: none;
    }

    .problemText {
      width: 100%;
      gap: 20px;
    }

    .problemTitle {
      font-size: 30px;
    }

    .problemBody {
      max-width: 100%;
    }

    .problemBody p {
      font-size: 14px;
      font-weight: 200;
    }

    .problemTagline {
      text-align: center;
      align-self: center;
    }
  }
</style>
