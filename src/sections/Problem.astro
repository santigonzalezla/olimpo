---
const largeImg = "https://www.figma.com/api/mcp/asset/9fe2f44b-410a-4f6e-be99-ea05a02fce5a";
const smallImg1 = "https://www.figma.com/api/mcp/asset/a528d682-c800-453c-91f1-43f69f79be7d";
const smallImg2 = "https://www.figma.com/api/mcp/asset/fb0e3f4f-00a6-4d37-b713-c49b125ef2a8";
const smallImg3 = "https://www.figma.com/api/mcp/asset/0edab0aa-2005-4de4-a978-2f1471910eea";
---

<section class="problem" id="proyecto">
  <div class="problemText">
    <h2 class="problemTitle">Conoce tu nuevo hogar: Olimpo</h2>
    <div class="problemBody">
      <p>
        Un proyecto residencial desarrollado en Valledupar, pensado para
        familias que buscan calidad de vida en un entorno moderno y bien
        ubicado.
      </p>
      <p>
        Apartaestudios y apartamentos de 3 alcobas disponibles en preventa,
        con espacios diseñados para el día a día de quienes merecen más.
      </p>
    </div>
    <a href="#contacto" class="problemCta">¡Hablemos Ya!</a>
    <p class="problemTagline">
      Arquitectura moderna · Acabados de calidad<br />Espacios que enamoran
    </p>
  </div>

  <div class="problemImages">
    <div class="problemSmalls">
      <img src={smallImg1} alt="Olimpo exterior" />
      <img src={smallImg2} alt="Olimpo exterior" />
      <img src={smallImg3} alt="Olimpo exterior" />
    </div>
    <div class="problemLarge">
      <img src={largeImg} alt="Olimpo proyecto" />
    </div>
  </div>
</section>

<style>
  .problem {
    display: flex;
    align-items: center;
    height: 800px;
    padding: 0 var(--px);
    gap: 100px;
    background: #fff;
  }

  .problemText {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 420px;
    flex-shrink: 0;
  }

  .problemTitle {
    font-family: var(--f-satoshi);
    font-weight: 700;
    font-size: 42px;
    line-height: 1.4;
    color: #131b23;
  }

  .problemBody {
    display: flex;
    flex-direction: column;
    gap: 16px;
    font-size: 16px;
    line-height: 1.4;
    color: var(--c-body);
    max-width: 315px;
  }

  .problemCta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 45px;
    width: 195px;
    background: var(--c-navy);
    color: #fff;
    font-family: var(--f-satoshi);
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .problemCta:hover {
    opacity: 0.8;
  }

  .problemTagline {
    font-family: var(--f-stardom);
    font-size: 14px;
    line-height: 1.4;
    color: #000;
  }

  .problemImages {
    display: grid;
    grid-template-columns: 195px 1fr;
    gap: 15px;
    height: 650px;
    flex: 1;
  }

  .problemSmalls {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .problemSmalls img {
    flex: 1;
    width: 195px;
    height: 194px;
    object-fit: cover;
  }

  .problemLarge img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
