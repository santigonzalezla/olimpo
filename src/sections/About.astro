---
import largeImgSrc from "../assets/images/fachada4.png";
import logoIn from "../assets/images/logoinconstructora.png";

const largeImg = largeImgSrc.src;
const logoCircle = logoIn.src;
---

<section class="about" id="ubicacion">
  <div class="aboutLeft">
    <div class="aboutPhotoWrap">
      <img class="aboutPhoto" src={largeImg} alt="IN Constructora" />
      <div class="aboutCard">
        <img class="aboutCardLogo" src={logoCircle} alt="IN Constructora logo" width="100" />
        <p class="aboutCardName">IN Constructora</p>
        <p class="aboutCardDesc">
          Con años de experiencia en el sector inmobiliario de Valledupar,
          Olimpo es nuestra nueva apuesta por una ciudad que merece espacios
          modernos.
        </p>
      </div>
    </div>
  </div>

  <div class="aboutRight">
    <h2 class="aboutTitle">Tu felicidad es nuestro compromiso</h2>
    <p class="aboutDesc">
      En IN Constructora creemos que un hogar es mucho más que cuatro paredes,
      es donde sucede la vida. Por eso cada proyecto lo diseñamos pensando en
      las familias que lo van a habitar, con calidad, transparencia y cuidado
      en cada detalle.
    </p>
    <a href="#contacto" class="aboutCta">¡Hablemos Ya!</a>
  </div>
</section>

<style>
  .about {
    display: flex;
    align-items: center;
    height: 800px;
    background: #fff;
    padding: 0 var(--px);
    gap: 96px;
  }

  .aboutLeft {
    flex-shrink: 0;
    width: 620px;
  }

  .aboutPhotoWrap {
    position: relative;
    width: 524px;
    height: 540px;
  }

  .aboutPhoto {
    width: 524px;
    height: 540px;
    object-fit: cover;
  }

  .aboutCard {
    position: absolute;
    bottom: 60px;
    right: -95px;
    width: 305px;
    height: 312px;
    background: linear-gradient(220deg, #474747 4%, #222 44%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px;
    box-shadow: 0 10px 15px rgba(151, 151, 151, 0.12);
  }

  .aboutCardLogo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
  }

  .aboutCardName {
    font-family: 'Satoshi', sans-serif;
    font-weight: 600;
    font-size: 22px;
    color: #fff;
    text-align: center;
  }

  .aboutCardDesc {
    font-family: 'Satoshi', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #e5e5e5;
    text-align: center;
    line-height: 1.5;
  }

  .aboutRight {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 512px;
  }

  .aboutTitle {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 42px;
    line-height: 1.4;
    color: var(--c-text);
  }

  .aboutDesc {
    font-family: 'Satoshi', sans-serif;
    font-weight: 300;
    font-size: 18px;
    line-height: 1.5;
    color: var(--c-body);
  }

  .aboutCta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 45px;
    width: 195px;
    background: var(--c-navy);
    color: #fff;
    font-family: 'Satoshi', sans-serif;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .aboutCta:hover {
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .about {
      height: auto;
      padding: 60px var(--px);
      gap: 48px;
    }

    .aboutLeft {
      width: 380px;
    }

    .aboutPhotoWrap {
      width: 100%;
      height: 420px;
    }

    .aboutPhoto {
      width: 100%;
      height: 420px;
    }

    .aboutCard {
      right: -40px;
      width: 240px;
      height: 260px;
    }

    .aboutTitle {
      font-size: 32px;
    }
  }

  @media (max-width: 767px) {
    .about {
      flex-direction: column;
      height: 100dvh;
      padding: 48px var(--px);
      gap: 28px;
      align-items: flex-start;
      justify-content: center;
    }

    .aboutLeft {
      width: 100%;
      flex-shrink: 0;
    }

    .aboutPhotoWrap {
      width: 100%;
      height: 300px;
    }

    .aboutPhoto {
      width: 100%;
      height: 300px;
    }

    .aboutCard {
      bottom: 0;
      right: 0;
      width: 200px;
      height: auto;
      padding: 16px;
      gap: 8px;
    }

    .aboutCardLogo {
      width: 56px;
      height: 56px;
    }

    .aboutCardName {
      font-size: 15px;
    }

    .aboutCardDesc {
      font-size: 11px;
    }

    .aboutRight {
      max-width: 100%;
      gap: 14px;
    }

    .aboutTitle {
      font-size: 28px;
    }

    .aboutDesc {
      font-size: 14px;
      font-weight: 300;
    }

    .aboutCta {
      width: 160px;
      height: 42px;
      font-size: 14px;
    }
  }
</style>
