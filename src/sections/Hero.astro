---
import Logo from "../components/hero/Logo.astro";
import NavLinks from "../components/hero/NavLinks.astro";
import NavCta from "../components/hero/NavCta.astro";
import HeroSlider from "../components/hero/HeroSlider.astro";

import locationIcon from "../assets/location.svg?url";
---

<section class="hero" id="inicio">
    <HeroSlider />

    <nav class="nav">
        <div class="navLeft"><Logo /></div>
        <div class="navCenter"><NavLinks /></div>
        <div class="navRight"><NavCta /></div>
    </nav>

    <div class="heroBody">
        <div class="heroContent">
            <p class="heroLocation">
                <img class="icon" src={locationIcon} alt="" />
                Valledupar, Cesar
            </p>
            <h1 class="heroTitle">Descubre tu nuevo lugar en el mundo.</h1>
            <p class="heroSubtitle">
                Conoce los espacios de este proyecto para ti y tu familia, con espacios
                cómodos y modernos donde podrás construir los momentos que más importan.
            </p>
            <div class="heroCtas">
                <a href="#contacto" class="btnFilled">Agenda tu Cita</a>
                <a href="#proyecto" class="btnOutline">¡Conocenos!</a>
            </div>
        </div>

        <div class="heroStats">
            <div class="stat">
                <span class="statNumber">2-3</span>
                <span class="statLabel">Habitaciones</span>
            </div>
            <div class="stat">
                <span class="statNumber">32+</span>
                <span class="statLabel">Apartamentos</span>
            </div>
            <div class="stat">
                <span class="statNumber">60+</span>
                <span class="statLabel">Metros Cuadrados</span>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        width: 100%;
        height: 800px;
        color: #FFF;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .nav {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        height: 100px;
        padding: 0 var(--px);
    }

    .navLeft,
    .navCenter,
    .navRight {
        flex: 1;
        display: flex;
        align-items: center;
    }

    .navCenter {
        justify-content: center;
    }

    .navRight {
        justify-content: flex-end;
    }

    .heroBody {
        position: relative;
        z-index: 2;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 48px var(--px) 48px;
    }

    .heroContent {
        display: flex;
        flex-direction: column;
        gap: 20px;
        max-width: 825px;
    }

    .heroLocation {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--f-stardom);
        font-size: 11px;
        text-transform: capitalize;
    }

    .heroTitle {
        font-family: var(--f-satoshi);
        font-weight: 700;
        font-size: 70px;
        line-height: 1.4;
    }

    .heroSubtitle {
        font-size: 16px;
        line-height: 1.4;
        max-width: 668px;
        opacity: 0.9;
    }

    .heroCtas {
        display: flex;
        gap: 16px;
        margin-top: 8px;
    }

    .btnFilled {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 45px;
        width: 160px;
        background: var(--c-navy);
        color: #fff;
        font-family: var(--f-satoshi);
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .btnFilled:hover {
        opacity: 0.8;
    }

    .btnOutline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 45px;
        width: 160px;
        border: 2px solid #fff;
        color: #fff;
        font-family: var(--f-satoshi);
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .btnOutline:hover {
        background: #fff;
        color: var(--c-navy);
    }

    .heroStats {
        display: flex;
        gap: 48px;
        align-self: flex-end;
    }

    .stat {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: #FFF;
    }

    .statNumber {
        font-family: var(--f-satoshi);
        font-weight: 700;
        font-size: 48px;
        line-height: 1.4;
    }

    .statLabel {
        font-family: var(--f-stardom);
        font-size: 14px;
        line-height: 1.4;
    }

    .icon {
        width: 15px;
        height: 15px;
        object-fit: contain;
        flex-shrink: 0;
    }
</style>
