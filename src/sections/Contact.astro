---
import ContactForm from "../components/contact/ContactForm.astro";

const mapImg = "https://www.figma.com/api/mcp/asset/fa824a05-d727-4bc1-b03f-c426da26b5c5";
---

<section class="contact" id="contacto">
  <div class="contactMap">
    <img src={mapImg} alt="Ubicación Olimpo" />
  </div>

  <div class="contactInfo">
    <h2 class="contactTitle">Reserva tu apartamento hoy</h2>
    <p class="contactDesc">
      Un asesor de Olimpo te contactará para resolver tus dudas y guiarte en
      el proceso. Sin compromisos, solo la información que necesitas para tomar
      la mejor decisión.
    </p>
    <ContactForm />
  </div>
</section>

<style>
  .contact {
    display: flex;
    align-items: center;
    height: 800px;
    background: var(--c-navy);
    padding: 0 var(--px);
    gap: 128px;
  }

  .contactMap {
    flex-shrink: 0;
    width: 569px;
    height: 616px;
    overflow: hidden;
  }

  .contactMap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .contactInfo {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contactTitle {
    font-family: var(--f-satoshi);
    font-weight: 700;
    font-size: 40px;
    line-height: 1.105;
    color: #fff;
    max-width: 554px;
  }

  .contactDesc {
    font-family: var(--f-satoshi);
    font-weight: 300;
    font-size: 18px;
    line-height: 1.5;
    color: #fff;
    max-width: 525px;
  }

  @media (max-width: 1024px) {
    .contact {
      height: auto;
      padding: 60px var(--px);
      gap: 48px;
    }

    .contactMap {
      width: 360px;
      height: 460px;
    }

    .contactTitle {
      font-size: 30px;
    }
  }

  @media (max-width: 767px) {
    .contact {
      flex-direction: column;
      height: 100dvh;
      padding: 0;
      gap: 0;
      align-items: stretch;
      overflow: hidden;
    }

    .contactMap {
      width: 100%;
      height: 300px;
      flex-shrink: 0;
    }

    .contactInfo {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      padding: 28px var(--px) 32px;
      gap: 16px;
    }

    .contactTitle {
      font-size: 24px;
    }

    .contactDesc {
      display: none;
    }
  }
</style>
